# Cloudflare Pages custom headers

# Long-cache static assets (they're versioned/stable)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# HTML: always revalidate so updates show immediately after a push
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Sensible security headers for a static marketing site
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'none'; frame-ancestors 'none'
